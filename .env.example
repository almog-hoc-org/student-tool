# Supabase — required for auth + persistence
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL="https://<your-project>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<your-project>"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"

# Optional: enable Gemini fallback for AI Advisor (legacy local-chat is being deprecated)
# Real RAG chat uses Supabase Edge Function — provider key lives in Supabase secrets, not here.
# VITE_GEMINI_API_KEY="<gemini-api-key>"
